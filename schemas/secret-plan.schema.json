{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://env-mapper-mcp.local/schemas/secret-plan.schema.json",
  "title": "Env Mapper Secret Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "schemaVersion",
    "toolVersion",
    "version",
    "provider",
    "generatedAt",
    "root",
    "summary",
    "actions",
    "warnings"
  ],
  "properties": {
    "mode": { "const": "dry-run" },
    "schemaVersion": { "const": "0.1" },
    "toolVersion": { "type": "string" },
    "version": { "type": "string" },
    "provider": { "type": "string" },
    "generatedAt": { "type": "string" },
    "root": { "type": "string" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actions", "secretKeys", "publicConfigKeys", "unusedCandidates"],
      "properties": {
        "actions": { "type": "integer", "minimum": 0 },
        "secretKeys": { "type": "integer", "minimum": 0 },
        "publicConfigKeys": { "type": "integer", "minimum": 0 },
        "unusedCandidates": { "type": "integer", "minimum": 0 }
      }
    },
    "actions": { "type": "array", "items": { "$ref": "#/$defs/action" } },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action",
        "provider",
        "key",
        "reason",
        "requiresValue",
        "applySupported",
        "findingIds",
        "sources"
      ],
      "properties": {
        "action": {
          "enum": ["mark_unused_candidate", "ensure_secret_key", "ensure_public_config_key"]
        },
        "provider": { "type": "string" },
        "key": { "type": "string" },
        "reason": { "type": "string" },
        "requiresValue": { "type": "boolean" },
        "applySupported": { "const": false },
        "findingIds": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "array", "items": { "$ref": "#/$defs/source" } }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "file", "line", "pattern"],
      "properties": {
        "kind": {
          "enum": ["declaration", "usage", "reference", "provider-reference", "dynamic-usage"]
        },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "pattern": { "type": "string" }
      }
    }
  }
}
